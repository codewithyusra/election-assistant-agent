# Google Gemini API Key (Required for AI-powered responses)
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key (Optional - for polling station locator)
# Get your key from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Sheets API (Optional - for analytics logging)
# Service account credentials JSON file path
GOOGLE_SHEETS_CREDENTIALS=./credentials.json
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Google YouTube Data API Key (Optional - for video search)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development
